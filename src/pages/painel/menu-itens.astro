---
import BtnDefault from "../../components/shared/BtnDefault.astro";
import LayoutPainel from "../../layouts/LayoutPainel.astro";
import type { ItemMenuDetalhes } from "@types";
const apiUrl = import.meta.env.PUBLIC_API_URL;
const base = import.meta.env.BASE_URL;
const itemMenuDetalhesResponse = await fetch(`${apiUrl}/menu-itens`);
const itemMenuDetalhesData = await itemMenuDetalhesResponse.json();
---

<LayoutPainel pageTitle="Todos os itens de menu cadastrados">
  <section id="menu-section">
    <div class="categorias">
      <a class="btn-default btn-primary" id="todos">Todos os itens</a>
      <a class="btn-default btn-primary" id="petiscos"
        >Petiscos & Acompanhamentos</a
      >
      <a class="btn-default btn-primary" id="principais">Pratos Principais</a>
      <a class="btn-default btn-primary" id="sobremesas">Sobremesas</a>
      <a class="btn-default btn-primary" id="drinks">Drinks da Casa</a>
      <a class="btn-default btn-primary" id="cervejas">Cervejas & Chopes</a>
    </div>
    <div class="menu-grid container"></div>
  </section>
</LayoutPainel>

<style>
  #menu-section {
    background-color: var(--white);
    padding: 96px 0;

    .categorias {
      display: flex;
      justify-content: center;
      gap: 40px;
    }

    .menu-grid {
      display: grid;
      gap: 40px;
      align-items: start;

      .section {
        h2 {
          font-size: 48px;
          font-weight: 600;
          text-align: center;
          text-transform: uppercase;
          color: var(--primary-color);
          margin: 96px 0 64px;
        }

        .cards {
          display: grid;
          grid-template-columns: 1fr 1fr 1fr;
          gap: 80px;

          .card {
            background: var(--secondary-color);
            border-radius: 16px;
            padding: 12px 12px 24px;
            text-align: center;
            color: white;

            img {
              width: 100%;
              border-radius: 14px;
            }

            h3 {
              font-weight: 600;
              font-size: 24px;
              letter-spacing: 0.2px;
              margin: 16px 0 12px;
            }

            p {
              font-size: 14px;
            }
          }
        }
      }
    }
  }

  @media (max-width: 1280px) {
    #menu-section {
      background-color: var(--white);
      padding: 64px 16px;

      .categorias {
        flex-wrap: wrap;
        gap: 24px;
      }

      .menu-grid {
        .section {
          h2 {
            font-size: 36px;
            margin: 80px 0 64px;
          }

          .cards {
            display: grid;
            grid-template-columns: 1fr 1fr;

            .card {
              h3 {
                font-size: 20px;
              }
            }
          }
        }
      }
    }
  }

  @media (max-width: 720px) {
    #menu-section {
      .categorias {
        gap: 16px;
        font-size: 14px;
      }

      .menu-grid {
        gap: 24px;

        .section {
          h2 {
            font-size: 24px;
          }

          .cards {
            display: grid;
            grid-template-columns: 1fr;
            gap: 40px;

            .card {
              h3 {
                font-size: 18px;
              }

              p {
                font-size: 12px;
              }
            }
          }
        }
      }
    }
  }
</style>

<script>
  import Toastify from "toastify-js";
  import "toastify-js/src/toastify.css";
  import type { ItemMenuDetalhes } from "@types";
  const apiUrl = import.meta.env.PUBLIC_API_URL;
  const base = import.meta.env.BASE_URL;
  const container = document.querySelector(".menu-grid.container");

  async function renderizarItens(categoria?: string) {
    console.log(categoria);
    
    container!.innerHTML = '';
    let itemMenuDetalhesResponse;
    if (categoria) {
      itemMenuDetalhesResponse = await fetch(
        `${apiUrl}/menu-itens/categoria/${categoria}`,
      );
    } else {
      itemMenuDetalhesResponse = await fetch(`${apiUrl}/menu-itens`);
    }
    const itemMenuDetalhesData = await itemMenuDetalhesResponse.json();

    itemMenuDetalhesData.forEach((itemMenuDetalhes: ItemMenuDetalhes) => {
      if (itemMenuDetalhes.itens.length > 0) {
        const section = document.createElement("div");
        section.classList.add("section");

        const h2 = document.createElement("h2");
        h2.textContent = itemMenuDetalhes.descricaoCategoria;
        section.appendChild(h2);

        const cardsDiv = document.createElement("div");
        cardsDiv.classList.add("cards");

        itemMenuDetalhes.itens.forEach((item) => {
          const article = document.createElement("article");
          article.classList.add("card");

          const img = document.createElement("img");
          img.src = item.base64Image;
          img.alt = item.descricaoAltImage;
          article.appendChild(img);

          const h3 = document.createElement("h3");
          h3.textContent = item.nome;
          article.appendChild(h3);

          const p = document.createElement("p");
          p.textContent = item.descricao;
          article.appendChild(p);

          const buttonsDiv = document.createElement("div");
          buttonsDiv.classList.add("flex", "card-buttons");

          const btnEdit = document.createElement("a");
          btnEdit.href = `${base}/painel/editar/${item.uuidItemMenu}`;
          btnEdit.classList.add("btn-default", "btn-edit");
          btnEdit.textContent = "Editar";
          buttonsDiv.appendChild(btnEdit);

          const btnDelete = document.createElement("a");
          btnDelete.classList.add("btn-default", "btn-delete");
          btnDelete.textContent = "Excluir";
          btnDelete.dataset.uuiditemmenu = item.uuidItemMenu;
          btnDelete.dataset.nomeitemmenu = item.nome;
          buttonsDiv.appendChild(btnDelete);

          article.appendChild(buttonsDiv);
          cardsDiv.appendChild(article);
        });
        section.appendChild(cardsDiv);
        container!.appendChild(section);
      }
    });
  }
  renderizarItens();
  document.querySelector("#todos")?.addEventListener("click", () => {
    renderizarItens();
  });
  document.querySelector("#petiscos")?.addEventListener("click", () => {
    renderizarItens("PETISCOS_E_ACOMPANHAMENTOS");
  });
  document.querySelector("#principais")?.addEventListener("click", () => {
    renderizarItens("PRATOS_PRINCIPAIS");
  });
  document.querySelector("#sobremesas")?.addEventListener("click", () => {
    renderizarItens("SOBREMESAS");
  });
  document.querySelector("#drinks")?.addEventListener("click", () => {
    renderizarItens("DRINKS_DA_CASA");
  });
  document.querySelector("#cervejas")?.addEventListener("click", () => {
    renderizarItens("CERVEJAS_E_CHOPES");
  });
  setTimeout(() => {
    const deleteButtons = document.querySelectorAll(".btn-delete");  
  deleteButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const uuidItemMenu = button.getAttribute("data-uuidItemMenu");
      const nomeItemMenu = button.getAttribute("data-nomeItemMenu");

      if (
        uuidItemMenu &&
        confirm(`Deseja realmente excluir o(a) ${nomeItemMenu}`)
      ) {
        await fetch(`${apiUrl}/menu-item/deletar/${uuidItemMenu}`, {
          method: "delete",
        })
          .then(async (res) => {
            const excluirData = await res.json();
            let backgroundColor;
            if (res.ok) {
              backgroundColor =
                "linear-gradient(to right, rgba(40, 167, 69, 0.8), rgba(25, 135, 84, 0.9))";
            } else {
              backgroundColor =
                "linear-gradient(to right, rgba(220, 53, 69, 0.85), rgba(139, 0, 0, 0.8))";
            }
            Toastify({
              text: excluirData.message,
              close: true,
              offset: {
                x: 12,
                y: 132,
              },
              style: {
                backgroundImage: backgroundColor,
                borderRadius: "12px",
                padding: "24px",
                fontSize: "18px",
                maxWidth: "380px",
              },
              onClick: function () {},
            }).showToast();
          })
          .catch((error) => {
            console.error(error);
            Toastify({
              text: "O servidor está fora do ar. Tente novamente mais tarde!",
              close: true,
              offset: {
                x: 12,
                y: 132,
              },
              style: {
                backgroundImage:
                  "linear-gradient(to right, rgba(220, 53, 69, 0.7), rgba(139, 0, 0, 0.85))",
                borderRadius: "12px",
                padding: "24px",
                fontSize: "18px",
                maxWidth: "380px",
              },
            }).showToast();
          })
          .finally(() => {
            setTimeout(() => {
              location.reload();
            }, 2000);
          });
      }
    });
  });
  }, 1000);
</script>

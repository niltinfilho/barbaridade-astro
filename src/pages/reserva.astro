---
import Layout from "../layouts/Layout.astro";
import HeroSubpages from "../components/shared/hero-subpages.astro";
import Sobre from "../components/Sobre.astro";
import Menu from "../components/Menu.astro";
import vintage from "../assets/vintage-82.png";

---

<Layout pageTitle="Reserva">
    <HeroSubpages
        textTitle="Faça sua <span>reserva</span> agora"
        textDescription="No Bar Baridade, cada mesa é um convite pra viver uma experiência única: drinks autorais, boa música e aquele clima que transforma qualquer quinta em sexta."
    />
    <section id="reserva-section">
        <div class="container flex form-wrapper">
            <div class="img-form"></div>
            <div class="form-content">
                <h2>Reserve sua mesa</h2>
                <p>
                    Porque algumas noites merecem ser planejadas (e brindadas
                    com estilo).
                </p>
                <form class="flex" id="form">
                    <div>
                        <label for="name">Nome completo*</label>
                        <input
                            type="text"
                            name="name"
                            id="name"
                            placeholder="Pra gente te chamar do jeito certo (e preparar seu lugar com carinho)"
                            class="inputs required"
                            oninput="nameValidate()"
                        />
                        <span class="span-required">
                            O nome deve ter no mínimo 3 caracteres
                        </span>
                    </div>
                    <div>
                        <label for="telefone"
                            >Telefone / WhatsApp* (Apenas números)</label
                        >
                        <input
                            type="tel"
                            name="telefone"
                            id="telefone"
                            placeholder="Caso precise confirmar ou ajustar o horário do seu brinde"
                            class="inputs required"
                            onblur="mascaraDeTelefone(this)"
                            oninput="telefoneValidate(this)"
                        />
                        <span class="span-required">
                            O telefone deve ter no mínimo 8 caracteres
                        </span>
                    </div>
                    <div>
                        <label for="email">E-mail*</label>
                        <input
                            type="email"
                            name="email"
                            id="email"
                            placeholder="Pra enviar a confirmação da reserva"
                            class="inputs required"
                            oninput="emailValidate()"
                        />
                        <span class="span-required">
                            O e-mail deve ser válido
                        </span>
                    </div>
                    <div class="form-two-columns flex">
                        <div>
                            <label for="data">Data da reserva*</label>
                            <input
                                type="date"
                                name="data"
                                id="data"
                                placeholder="Escolha o dia da sua noite Bar-Baridade"
                                class="inputs required"
                                oninput="dataValidate()"
                            />
                            <span class="span-required">
                                A data da reserva deve ser válida
                            </span>
                        </div>
                        <div>
                            <label for="numero">Número de pessoas*</label>
                            <input
                                type="number"
                                name="numero"
                                id="numero"
                                placeholder="Mais gente, mais brindes"
                                class="inputs required"
                                oninput="numeroValidate()"
                            />
                            <span class="span-required">
                                O número de pessoas deve ser maior ou igual a 1
                            </span>
                        </div>
                    </div>
                    <div>
                        <button
                            id="button"
                            type="button"
                            class="disabled"
                            disabled
                            onclick="sendWhatsapp()"
                        >
                            Confirmar reserva
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <section class="iframe-maps">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d467688.89495119266!2d-46.5952992!3d-23.6824124!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce448183a461d1%3A0x9ba94b08ff335bae!2zU8OjbyBQYXVsbywgU1A!5e0!3m2!1spt-BR!2sbr!4v1764451555763!5m2!1spt-BR!2sbr"
                width="100%"
                height="450"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
        </section>
    </section>
  <Sobre />
  <Menu />
</Layout>

<style>
    #reserva-section {
        background-color: var(--primary-color);
        padding: 96px 0;

        .form-wrapper {
            background-color: var(--light-grey);
            border-radius: 12px;

            .img-form {
                background: url("../assets/about/img-about-1.jpg") center center
                    no-repeat;
                background-size: cover;
                width: 640px;
                height: 600px;
                border-radius: 12px 0 0 12px;
            }

            .form-content {
                padding: 0 32px;
                width: 50%;

                h2 {
                    font-size: 20px;
                    font-weight: 600;
                    margin-bottom: 12px;
                }

                form {
                    margin-top: 24px;
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 24px;

                    .form-two-columns {
                        gap: 40px;

                        div {
                            width: 50%;
                        }
                    }

                    div {
                        width: 100%;

                        label {
                            display: block;
                            margin-bottom: 8px;
                        }

                        input {
                            width: 100%;
                            padding: 12px;
                            border: 2px solid var(--medium-grey);
                            border-radius: 12px;
                            background-color: var(--medium-grey);
                            font-size: 16px;
                            font-family: Roboto;
                        }

                        input:focus {
                            outline: none;
                        }

                        span {
                            display: none;
                            margin: 6px 0 0 3px;
                            color: red;
                            font-size: 12px;
                        }

                        button {
                            width: 100%;
                            padding: 16px;
                            border-radius: 12px;
                            border: none;
                            background-color: var(--secondary-color);
                            color: var(--white);
                            text-transform: uppercase;
                            font-weight: 600;
                            font-size: 18px;
                            font-family: Roboto;
                            transition: all 0.2s;
                            cursor: pointer;
                        }

                        button:hover {
                            background-color: var(--primary-color);
                            color: var(--secondary-color);
                        }

                        button.disabled {
                            opacity: 0.6;
                            cursor: not-allowed;
                        }

                        button.disabled:hover {
                            background-color: var(--red);
                            color: var(--white);
                        }
                    }
                }
            }
        }
    }

    .iframe-maps {
        padding: 96px 0;
        max-width: 960px;
        margin: 0 auto;

        iframe {
            border-radius: 12px;
        }
    }

    @media (max-width: 1280px) {
        #reserva-section {
            padding: 64px 16px;

            .form-wrapper {
                flex-direction: column;

                .img-form {
                    background: url("../images/img-about-1.jpg") center center
                        no-repeat;
                    background-size: cover;
                    width: 100%;
                    height: 400px;
                    border-radius: 12px 12px 0px 0px;
                }

                .form-content {
                    padding: 64px 32px;
                    width: 100%;

                    form {
                        margin-top: 40px;
                    }
                }
            }
        }

        .iframe-maps {
            padding: 64px 16px;
        }
    }

    @media (max-width: 720px) {
        #reserva-section {
            .form-wrapper {
                .img-form {
                    background: url("../images/img-about-1.jpg") center center
                        no-repeat;
                    background-size: cover;
                    width: 100%;
                    height: 280px;
                    border-radius: 12px 12px 0 0;
                }

                .form-content {
                    padding: 32px 16px;
                    width: 100%;

                    form {
                        .form-two-columns {
                            gap: 24px;

                            div {
                                width: 100%;
                            }
                        }

                        div {
                            label {
                                font-size: 14px;
                            }

                            input {
                                font-size: 12px;
                            }

                            span {
                                font-size: 8px;
                            }

                            button {
                                font-size: 14px;
                            }
                        }
                    }
                }
            }
        }
    }
</style>

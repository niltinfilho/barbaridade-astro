---
import type { ItemMenuDetalhes } from "@types";
import CardMenuItem from "./CardMenuItem.astro";

interface Props {
  menuItens: ItemMenuDetalhes[];
}

const { menuItens } = Astro.props;
---

<div class="menu-grid container">
  {
    menuItens.map(
      (itemMenu) =>
        itemMenu.itens.length > 0 && (
          <div class="section">
            <h2>{itemMenu.descricaoCategoria}</h2>
            <div class="cards">
              {itemMenu.itens.map((item) => (
                <CardMenuItem
                  base64Image={item.base64Image}
                  descricaoAltImage={item.descricaoAltImage}
                  nome={item.nome}
                  descricao={item.descricao}
                />
              ))}
            </div>
          </div>
        ),
    )
  }
</div>
<style>
  .menu-grid {
    display: grid;
    gap: 40px;
    align-items: start;

    .section {
      h2 {
        font-size: 48px;
        font-weight: 600;
        text-align: center;
        text-transform: uppercase;
        color: var(--primary-color);
        margin: 96px 0 64px;
      }

      .cards {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 80px;

        .card {
          background: var(--secondary-color);
          border-radius: 16px;
          padding: 12px 12px 24px;
          text-align: center;
          color: white;

          img {
            width: 100%;
            border-radius: 14px;
          }

          h3 {
            font-weight: 600;
            font-size: 24px;
            letter-spacing: 0.2px;
            margin: 16px 0 12px;
          }

          p {
            font-size: 14px;
          }
        }
      }
    }
  }

  @media (max-width: 1280px) {
    .menu-grid {
      .section {
        h2 {
          font-size: 36px;
          margin: 80px 0 64px;
        }

        .cards {
          display: grid;
          grid-template-columns: 1fr 1fr;

          .card {
            h3 {
              font-size: 20px;
            }
          }
        }
      }
    }
  }

  @media (max-width: 720px) {
    .menu-grid {
      gap: 24px;

      .section {
        h2 {
          font-size: 24px;
        }

        .cards {
          display: grid;
          grid-template-columns: 1fr;
          gap: 40px;

          .card {
            h3 {
              font-size: 18px;
            }

            p {
              font-size: 12px;
            }
          }
        }
      }
    }
  }
</style>

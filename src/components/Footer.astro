---
import logoBarBaridade from "../assets/id/logo-bar-baridade-horizontal-original.svg";
import bannerFooter from "../assets/banner-bar-baridade-footer.jpg";
const bgImage = `url(${bannerFooter.src})`;
import BtnDefault from "./shared/BtnDefault.astro";
---

<footer id="footer">
  <section class="cta-footer">
    <h2>Viva a experiência Bar-Baridade</h2>
    <p>
      No Bar-Baridade, cada noite é um convite pra brindar o que a vida tem de
      melhor: boa música, bons drinks e boas risadas. Aqui, a sofisticação tem
      sabor, e o humor é o ingrediente secreto de cada receita.
    </p>
    <BtnDefault label="Fazer reserva agora" />
  </section>
  <section class="info-footer container">
    <div class="flex info-footer-top">
      <img src={logoBarBaridade.src} alt="" />
      <div>
        <h2>Informações de Contato</h2>
        <ul>
          <li>
            Av. das Boas Noites, 123 <br />
            Bairro Alto da Lua, São Paulo – SP
          </li>
          <li>(11) 99999-9999</li>
          <li>@bar_baridade.sp</li>
        </ul>
      </div>
      <div>
        <h2>Links Importantes</h2>
        <ul>
          <li><a href="sobre.html">Sobre</a></li>
          <li><a href="menu.html">Menu</a></li>
          <li><a href="calendario.html">Calendário</a></li>
          <li><a href="reserva.html">Fazer reserva</a></li>
        </ul>
      </div>
    </div>
    <div class="flex info-footer-bottom">
      <p>&copy; 2025 Bar-Baridade. Todos os direitos reservados.</p>
      <p>
        <a href="#">Política de Privacidade</a> | <a href="#">Termos de Uso</a>
      </p>
    </div>
  </section>
</footer>

<style define:vars={{ bgImage }}>
  footer {
    background-color: #0f0f0f;

    .cta-footer {
      padding: 96px 0;
      background: var(--bgImage) center center no-repeat;
      background-size: cover;
      text-align: center;

      h2 {
        font-size: 48px;
        font-weight: 600;
        color: var(--white);
        margin-bottom: 16px;
        text-transform: uppercase;
      }

      p {
        color: var(--white);
        max-width: 670px;
        margin: 0 auto;
      }

      a {
        display: block;
        margin: 40px auto 0;
        width: fit-content;
      }
    }

    .info-footer {
      padding: 96px 0 40px;

      .info-footer-top {
        justify-content: space-between;
        align-items: flex-start;

        img {
          width: 240px;
        }

        h2 {
          color: var(--white);
          font-size: 20px;
          margin-bottom: 24px;
        }

        ul {
          li,
          a {
            color: var(--white);
            transition: all 0.2s;
            padding: 8px 0;
          }

          a:hover {
            color: var(--primary-color);
          }
        }
      }

      .info-footer-bottom {
        justify-content: space-between;
        margin-top: 80px;

        p,
        a {
          color: var(--white);
          transition: all 0.2s;
          padding: 8px 0;
        }

        a:hover {
          color: var(--primary-color);
        }
      }
    }
  }

  @media (max-width: 1280px) {
    footer {
      .cta-footer {
        padding: 64px 16px;

        h2 {
          font-size: 36px;
        }
      }

      .info-footer {
        padding: 64px 16px 40px;

        .info-footer-top {
          justify-content: space-between;
          align-items: flex-start;

          img {
            width: 200px;
          }

          h2 {
            font-size: 18px;
          }
        }

        .info-footer-bottom {
          margin-top: 64px;
        }
      }
    }
  }

  @media (max-width: 720px) {
    footer {
      .cta-footer {
        h2 {
          font-size: 24px;
        }

        a {
          margin: 24px auto 0;
        }
      }

      .info-footer {
        .info-footer-top {
          gap: 40px;

          img {
            width: 180px;
          }
        }

        .info-footer-bottom {
          align-items: center;
          text-align: center;
          margin-top: 40px;
        }
      }
    }
  }
</style>
